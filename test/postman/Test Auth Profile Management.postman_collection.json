          "name": "Test Update Password - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Use test user credentials",
                  "const currentPassword = pm.globals.get('test_password') || 'TestPassword123!';",
                  "const newPassword = 'NewSecure456!Pass';",
                  "// old current test password TestPassword123!",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    identifier: pm.globals.get('test_email') || 'test@example.com',",
                  "    currentPassword: currentPassword,",
                  "    newPassword: newPassword,",
                  "    confirmNewPassword: newPassword",
                  "});",
                  "",
                  "// Store for reverting later",
                  "pm.collectionVariables.set('temp_new_password', newPassword);",
                  "pm.collectionVariables.set('temp_old_password', currentPassword);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Successful password update",
                  "pm.test(\"Response status should be 200 for successful password update\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Response contains success message",
                  "pm.test(\"Response should contain success message\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('message');",
                  "    pm.expect(response.message).to.include('Password updated successfully');",
                  "});",
                  "",
                  "// Test 3: Response contains timestamp",
                  "pm.test(\"Response should contain timestamp\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('timestamp');",
                  "    pm.expect(response.timestamp).to.be.a('string');",
                  "});",
                  "",
                  "// Test 4: Timestamp is valid ISO 8601 format",
                  "pm.test(\"Timestamp should be valid ISO 8601 date string\", () => {",
                  "    const response = pm.response.json();",
                  "    const timestamp = new Date(response.timestamp);",
                  "    pm.expect(timestamp.toISOString()).to.equal(response.timestamp);",
                  "});",
                  "",
                  "// Test 5: Response structure validation",
                  "pm.test(\"Response contains expected properties only\", () => {",
                  "    const response = pm.response.json();",
                  "    const keys = Object.keys(response);",
                  "    pm.expect(keys).to.have.lengthOf(2);",
                  "    pm.expect(keys).to.include.members(['message', 'timestamp']);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
