      "name": "Profile Update Tests",
      "item": [
        {
          "name": "Test Update Profile - Timezone",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set up profile update request",
                  "const newTimezone = 'America/New_York';",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    timezone: newTimezone,",
                  "    first_name: 'UpdatedFirst',",
                  "    last_name: 'UpdatedLast',",
                  "    phone: '+19876543210'",
                  "});",
                  "",
                  "pm.collectionVariables.set('expected_timezone', newTimezone);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Successful profile update",
                  "pm.test(\"Response status should be 200 for successful profile update\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Response structure validation",
                  "pm.test(\"Response should contain updated user object\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('message');",
                  "    pm.expect(response).to.have.property('user');",
                  "    pm.expect(response.user).to.be.an('object');",
                  "});",
                  "",
                  "// Test 3: Verify updated fields",
                  "pm.test(\"User profile should contain updated values\", () => {",
                  "    const response = pm.response.json();",
                  "    const user = response.user;",
                  "    const requestBody = JSON.parse(pm.request.body.raw);",
                  "    ",
                  "    pm.expect(user.timezone).to.equal(requestBody.timezone);",
                  "    pm.expect(user.first_name).to.equal(requestBody.first_name);",
                  "    pm.expect(user.last_name).to.equal(requestBody.last_name);",
                  "    pm.expect(user.phone).to.equal(requestBody.phone);",
                  "});",
                  "",
                  "// Test 4: Verify user ID and email unchanged",
                  "pm.test(\"User ID and email should remain unchanged\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.user).to.have.property('id');",
                  "    pm.expect(response.user).to.have.property('email');",
                  "    pm.expect(response.user.email).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
