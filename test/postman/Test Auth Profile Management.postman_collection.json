        {
          "name": "Test Update Password - Revert to Original",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Revert password back to original",
                  "// The new password that was set in the previous test",
                  "const newPassword = 'NewSecure456!Pass';",
                  "// The original password to revert back to",
                  "const oldPassword = 'TestPassword123!';",
                  "",
                  "// Get the identifier",
                  "const identifier = pm.globals.get('test_email') || 'test@example.com';",
                  "",
                  "// Log values for debugging",
                  "console.log('=== Password Revert Debug Info ===');",
                  "console.log('Identifier:', identifier);",
                  "console.log('Current Password (new):', newPassword);",
                  "console.log('New Password (reverting to old):', oldPassword);",
                  "console.log('Confirm New Password:', oldPassword);",
                  "",
                  "// Set the request body",
                  "const bodyData = {",
                  "    identifier: identifier,",
                  "    currentPassword: newPassword,",
                  "    newPassword: oldPassword,",
                  "    confirmNewPassword: oldPassword",
                  "};",
                  "",
                  "console.log('Request Body:', JSON.stringify(bodyData, null, 2));",
                  "",
                  "// Update the request body",
                  "pm.request.body.raw = JSON.stringify(bodyData);",
                  "",
                  "// Ensure Content-Type header is set",
                  "pm.request.headers.upsert({",
                  "    key: 'Content-Type',",
                  "    value: 'application/json'",
                  "});",
                  "",
                  "console.log('Pre-request script completed - body set successfully');"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Password revert successful",
                  "pm.test(\"Password reverted successfully\", () => {",
                  "    pm.response.to.have.status(200);",
                  "    console.log('✓ Password reverted to original value');",
                  "});",
                  "",
                  "// Clean up temp variables",
                  "pm.collectionVariables.unset('temp_new_password');",
                  "pm.collectionVariables.unset('temp_old_password');"
                ],
