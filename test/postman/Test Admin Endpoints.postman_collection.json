        {
          "name": "Test Get All Users - With Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Response status and structure",
                  "pm.test(\"Response should have status 200 and correct structure\", () => {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    ",
                  "    // Validate response structure",
                  "    pm.expect(response).to.have.property('users');",
                  "    pm.expect(response).to.have.property('total');",
                  "    pm.expect(response).to.have.property('requestedBy');",
                  "    pm.expect(response).to.have.property('filters');",
                  "    ",
                  "    // Validate data types",
                  "    pm.expect(response.users).to.be.an('array');",
                  "    pm.expect(response.total).to.be.a('number');",
                  "    pm.expect(response.requestedBy).to.be.a('string');",
                  "    pm.expect(response.filters).to.be.an('object');",
                  "});",
                  "",
                  "// Test 2: Pagination parameters applied correctly",
                  "pm.test(\"Pagination parameters should be applied correctly\", () => {",
                  "    // Extract limit and offset from query parameters",
                  "    const limitParam = pm.request.url.query.get('limit');",
                  "    const offsetParam = pm.request.url.query.get('offset');",
                  "    ",
                  "    const limit = parseInt(limitParam);",
                  "    const offset = parseInt(offsetParam);",
                  "    ",
                  "    pm.expect(limit).to.equal(5);",
                  "    pm.expect(offset).to.equal(2);",
                  "    ",
                  "    // Validate that results don't exceed limit",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.users.length).to.be.at.most(limit);",
                  "});",
                  "",
                  "// Test 3: Results count validation",
                  "pm.test(\"Results should not exceed limit from query parameters\", () => {",
                  "    const response = pm.response.json();",
                  "    const limitParam = pm.request.url.query.get('limit');",
                  "    const limit = parseInt(limitParam);",
                  "    ",
                  "    pm.expect(response.users.length).to.be.at.most(limit);",
                  "});",
                  "",
                  "// Test 4: User objects have required properties",
                  "pm.test(\"Each user should have required properties\", () => {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    response.users.forEach(user => {",
                  "        pm.expect(user).to.have.property('id');",
                  "        pm.expect(user).to.have.property('username');",
                  "        pm.expect(user).to.have.property('email');",
                  "        pm.expect(user).to.have.property('role');",
                  "        pm.expect(user).to.have.property('roleName');",
                  "        pm.expect(user).to.have.property('timezone');",
                  "        pm.expect(user).to.have.property('created_at');",
                  "        pm.expect(user).to.have.property('updated_at');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/gdt/admin/users?limit=5&offset=2",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "gdt",
                "admin",
                "users"
              ],
              "query": [
