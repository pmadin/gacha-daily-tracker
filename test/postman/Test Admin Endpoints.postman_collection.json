		{
			"name": "User List Tests",
			"item": [
				{
					"name": "Test Get All Users - Admin Access",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Admin can access user list",
									"pm.test(\"Admin should have access to user list\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Response structure validation",
									"pm.test(\"Response should contain users array and pagination info\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('users');",
									"    pm.expect(response.users).to.be.an('array');",
									"    pm.expect(response).to.have.property('total');",
									"    pm.expect(response).to.have.property('limit');",
									"    pm.expect(response).to.have.property('offset');",
									"});",
									"",
									"// Test 3: User object structure",
									"pm.test(\"Each user should have required fields\", () => {",
									"    const response = pm.response.json();",
									"    if (response.users.length > 0) {",
									"        const user = response.users[0];",
									"        pm.expect(user).to.have.property('id');",
									"        pm.expect(user).to.have.property('username');",
									"        pm.expect(user).to.have.property('email');",
									"        pm.expect(user).to.have.property('role');",
									"        pm.expect(user).to.have.property('created_at');",
									"    }",
									"});",
									"",
									"// Test 4: Pagination defaults",
									"pm.test(\"Default pagination should be applied\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response.limit).to.be.a('number');",
									"    pm.expect(response.offset).to.equal(0);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/gdt/admin/users",
							"host": ["{{base_url}}"],
							"path": ["gdt", "admin", "users"]
						}
					}
				},
				{
					"name": "Test Get All Users - With Pagination",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Pagination parameters applied",
									"pm.test(\"Pagination parameters should be applied correctly\", () => {",
									"    pm.response.to.have.status(200);",
									"    const response = pm.response.json();",
									"    pm.expect(response.limit).to.equal(5);",
									"    pm.expect(response.offset).to.equal(2);",
									"    pm.expect(response.users.length).to.be.at.most(5);",
									"});",
									"",
									"// Test 2: Results count validation",
									"pm.test(\"Results should not exceed limit\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response.users.length).to.be.at.most(response.limit);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/gdt/admin/users?limit=5&offset=2",
							"host": ["{{base_url}}"],
							"path": ["gdt", "admin", "users"],
							"query": [
								{
									"key": "limit",
									"value": "5"
								},
								{
									"key": "offset",
									"value": "2"
								}
							]
						}
					}
				},
				{
					"name": "Test Get All Users - Filter by Role",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Role filter applied",
									"pm.test(\"Should return users filtered by role\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: All users have specified role",
									"pm.test(\"All returned users should have role 1\", () => {",
									"    const response = pm.response.json();",
									"    if (response.users.length > 0) {",
