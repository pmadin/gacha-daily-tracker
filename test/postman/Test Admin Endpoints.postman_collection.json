      "item": [
        {
          "name": "Test Update Role - User to Premium (Admin)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Use test user to promote",
                  "const username = pm.globals.get('test_username') || 'test_userROLE1';",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    newRole: 2,",
                  "    reason: 'Promoting user to premium for test purposes'",
                  "});",
                  "",
                  "pm.collectionVariables.set('test_target_username', username);",
                  "pm.collectionVariables.set('test_expected_role', 2);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Successful role update",
                  "pm.test(\"Response status should be 200 for successful role update\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Response structure validation",
                  "pm.test(\"Response should contain role update details\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('message');",
                  "    pm.expect(response).to.have.property('user');",
                  "    pm.expect(response).to.have.property('changedBy');",
                  "    pm.expect(response).to.have.property('reason');",
                  "    pm.expect(response).to.have.property('timestamp');",
                  "});",
                  "",
                  "// Test 3: Verify role was updated",
                  "pm.test(\"User role should be updated to premium (2)\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.user).to.have.property('oldRole');",
                  "    pm.expect(response.user).to.have.property('newRole');",
                  "    pm.expect(response.user.newRole).to.equal(2);",
                  "    console.log(`✓ Role updated: ${response.user.oldRole} → ${response.user.newRole}`);",
                  "});",
                  "",
                  "// Test 4: Verify user details in response",
                  "pm.test(\"User object should contain complete information\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.user).to.have.property('id');",
                  "    pm.expect(response.user).to.have.property('username');",
                  "    pm.expect(response.user).to.have.property('email');",
                  "    pm.expect(response.user).to.have.property('oldRoleName');",
                  "    pm.expect(response.user).to.have.property('newRoleName');",
                  "});",
                  "",
                  "// Test 5: Verify audit trail",
                  "pm.test(\"Response should contain audit information\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.changedBy).to.be.a('string').and.not.be.empty;",
                  "    pm.expect(response.reason).to.be.a('string').and.not.be.empty;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
