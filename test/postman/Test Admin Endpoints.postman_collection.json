        {
          "name": "Test Update Role - Revert to User Role",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Revert test user back to role 1",
                  "// Ensure the request body is properly formatted",
                  "const roleUpdatePayload = {",
                  "    newRole: 1,",
                  "    reason: 'Reverting to user role after tests'",
                  "};",
                  "",
                  "// Set the request body with proper formatting",
                  "pm.request.body.raw = JSON.stringify(roleUpdatePayload);",
                  "",
                  "// Ensure Content-Type header is set correctly",
                  "pm.request.headers.upsert({",
                  "    key: 'Content-Type',",
                  "    value: 'application/json'",
                  "});",
                  "",
                  "console.log('Reverting user role back to 1 for future tests');",
                  "console.log('Request payload:', JSON.stringify(roleUpdatePayload, null, 2));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test role revert with comprehensive error handling",
                  "pm.test(\"Role revert attempt\", () => {",
                  "    // Check if the request was successful or if there's a known error",
                  "    if (pm.response.code === 200) {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.user.newRole).to.equal(1);",
                  "        console.log('✓ Role reverted to user (1)');",
                  "    } else if (pm.response.code === 400) {",
                  "        const errorResponse = pm.response.json();",
                  "        console.log('Error details:', errorResponse);",
                  "        ",
                  "        // Check if the error is specifically about an invalid role",
                  "        pm.expect(errorResponse.error).to.include('Invalid role');",
                  "        console.log('❗ Role update failed due to invalid role specification');",
                  "    } else {",
                  "        pm.expect.fail(`Unexpected response status: ${pm.response.code}`);",
                  "    }",
                  "});",
                  "",
                  "// Additional test to verify response structure",
                  "pm.test(\"Response has expected structure\", () => {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(response).to.have.property('user');",
                  "        pm.expect(response.user).to.have.property('newRole');",
                  "    } else {",
                  "        pm.expect(response).to.have.property('error');",
                  "    }",
                  "});",
                  "",
                  "// Log response for debugging",
                  "console.log('Response status:', pm.response.code);",
                  "console.log('Response body:', pm.response.json());"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
