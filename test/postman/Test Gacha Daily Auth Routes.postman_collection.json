				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test 1: Response status should be 403 for invalid reg token\r",
							"pm.test(\"Should return 403 for invalid registration token\", () => {\r",
							"    pm.response.to.have.status(403);\r",
							"});\r",
							"\r",
							"// Test 2: Check for proper error message when registration token is invalid\r",
							"pm.test(\"Should return proper error message for invalid token\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response).to.have.property('error').that.includes('Invalid registration token');\r",
							"    pm.expect(response).to.have.property('hint').that.includes('Contact the administrator');\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
