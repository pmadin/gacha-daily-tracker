	"item": [
		{
			"name": "Test Register",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Create a NEW test user for registration testing (separate from login tests)\r",
							"const timestamp = Date.now();\r",
							"const registrationData = {\r",
							"    username: \"reg_test_\" + timestamp,\r",
							"    email: \"regtest\" + timestamp + \"@example.com\",\r",
							"    password: \"MySecure123!Pass\",\r",
							"    confirmPassword: \"MySecure123!Pass\",\r",
							"    registrationToken: \"e6b1228b6525d690bfc64ab355db000c1d9a49d921c97bbb9166a627d200c66437d2dfd53f2ea1d3ae2e173593732935c11b9418507a79fb6f39864ba6b83fc6\",\r",
							"    first_name: \"RegTest\",\r",
							"    last_name: \"User\",\r",
							"    phone: \"+1234567890\",\r",
							"    timezone: \"America/Los_Angeles\"\r",
							"};\r",
							"\r",
							"pm.request.body.raw = JSON.stringify(registrationData);\r",
							"\r",
							"// Store registration data (separate from existing test users)\r",
							"pm.globals.set(\"new_reg_username\", registrationData.username);\r",
							"pm.globals.set(\"new_reg_email\", registrationData.email);\r",
							"pm.globals.set(\"new_reg_password\", registrationData.password);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test 1: Response should contain all required user fields from documentation\r",
							"pm.test(\"Response should contain complete user object with all documented fields\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response).to.have.property('message');\r",
							"    pm.expect(response).to.have.property('user');\r",
							"    \r",
							"    const user = response.user;\r",
							"    pm.expect(user).to.have.property('id').that.is.a('number');\r",
							"    pm.expect(user).to.have.property('username').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('email').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('timezone').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('first_name').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('last_name').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('phone').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('role').that.is.a('number');\r",
							"    pm.expect(user).to.have.property('created_at').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('detected_timezone').that.is.a('boolean');\r",
							"});\r",
							"\r",
							"// Test 2: Security info should be present as documented\r",
							"pm.test(\"Response should contain security information\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response).to.have.property('security_info');\r",
							"    \r",
							"    const securityInfo = response.security_info;\r",
							"    pm.expect(securityInfo).to.have.property('hash_algorithm').that.equals('bcrypt');\r",
							"    pm.expect(securityInfo).to.have.property('salt_rounds').that.is.a('number');\r",
							"    pm.expect(securityInfo).to.have.property('additional_security').that.is.an('array');\r",
							"    pm.expect(securityInfo.additional_security).to.include.members(['pepper', 'timing-attack-protection', 'strong-password-policy']);\r",
							"});\r",
							"\r",
							"// Test 3: User data should match input values\r",
							"pm.test(\"User data should match provided registration data\", () => {\r",
							"    const response = pm.response.json();\r",
							"    const user = response.user;\r",
							"    const requestBody = JSON.parse(pm.request.body.raw);\r",
							"    \r",
							"    pm.expect(user.username).to.equal(requestBody.username);\r",
							"    pm.expect(user.email).to.equal(requestBody.email);\r",
							"    pm.expect(user.first_name).to.equal(requestBody.first_name);\r",
							"    pm.expect(user.last_name).to.equal(requestBody.last_name);\r",
							"    pm.expect(user.phone).to.equal(requestBody.phone);\r",
							"    pm.expect(user.timezone).to.equal(requestBody.timezone);\r",
							"    pm.expect(user.role).to.equal(1); // Default role as per documentation\r",
							"});\r",
							"\r",
							"// Test 4: Timezone detection should be correct\r",
							"pm.test(\"Timezone detection should be false when timezone is provided\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response.user.detected_timezone).to.be.false;\r",
							"});\r",
							"\r",
							"// Test 5: Created timestamp should be valid ISO date\r",
							"pm.test(\"Created timestamp should be valid ISO date format\", () => {\r",
							"    const response = pm.response.json();\r",
							"    const createdAt = new Date(response.user.created_at);\r",
							"    pm.expect(createdAt.toISOString()).to.equal(response.user.created_at);\r",
							"});\r",
							"\r",
							"// Test 6: Store NEW user ID for subsequent tests (separate from existing test users)\r",
							"pm.test(\"Store NEW registration user ID\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.globals.set(\"new_reg_user_id\", response.user.id);\r",
							"    console.log(\"New registration user ID stored:\", response.user.id);\r",
							"});\r",
							"\r",
							"// Test 7: Response status should be 201 for successful registration\r",
							"pm.test(\"Response status should be 201 for successful registration\", () => {\r",
							"    pm.response.to.have.status(201);\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
