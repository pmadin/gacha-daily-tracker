		{
			"name": "Test Login",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Updated test users from DB\r",
							"const existingTestUsers = [\r",
							"    { email: \"test1754082456666@example.com\", username: \"test_user_1754082456666\" },\r",
							"    { email: \"test1754082501144@example.com\", username: \"test_user_1754082501144\" },\r",
							"    { email: \"test1754082754288@example.com\", username: \"test_user_1754082754288\" }\r",
							"];\r",
							"\r",
							"// Use the first available test user\r",
							"const testUser = existingTestUsers[0];\r",
							"\r",
							"pm.request.body.raw = JSON.stringify({\r",
							"    email: testUser.email,\r",
							"    password: \"MySecure123!Pass\" // All test users should have this password\r",
							"});\r",
							"\r",
							"// Store credentials for subsequent tests\r",
							"pm.globals.set(\"test_email\", testUser.email);\r",
							"pm.globals.set(\"test_password\", \"MySecure123!Pass\");\r",
							"pm.globals.set(\"test_username\", testUser.username);\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test 1: Response should contain all documented login fields\r",
							"pm.test(\"Response should contain complete login response structure\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response).to.have.property('message').that.equals('Login successful');\r",
							"    pm.expect(response).to.have.property('token').that.is.a('string');\r",
							"    pm.expect(response).to.have.property('user').that.is.an('object');\r",
							"    pm.expect(response).to.have.property('expires_in').that.equals('30 days');\r",
							"});\r",
							"\r",
							"// Test 2: User object should contain documented fields\r",
							"pm.test(\"User object should contain all documented fields\", () => {\r",
							"    const response = pm.response.json();\r",
							"    const user = response.user;\r",
							"    \r",
							"    pm.expect(user).to.have.property('id').that.is.a('number');\r",
							"    pm.expect(user).to.have.property('username').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('email').that.is.a('string');\r",
							"    pm.expect(user).to.have.property('role').that.is.a('number');\r",
							"    pm.expect(user).to.have.property('timezone').that.is.a('string');\r",
							"});\r",
							"\r",
							"// Test 3: JWT token should be valid format\r",
							"pm.test(\"JWT token should be valid format\", () => {\r",
							"    const response = pm.response.json();\r",
							"    const token = response.token;\r",
							"    \r",
							"    // JWT should have 3 parts separated by dots\r",
							"    const tokenParts = token.split('.');\r",
							"    pm.expect(tokenParts).to.have.lengthOf(3);\r",
							"    \r",
							"    // Store token for authenticated requests\r",
							"    pm.globals.set(\"auth_token\", token);\r",
							"});\r",
							"\r",
							"// Test 4: User data should match registered user\r",
							"pm.test(\"Returned user should match the existing test user\", () => {\r",
							"    const response = pm.response.json();\r",
							"    const user = response.user;\r",
							"    \r",
							"    pm.expect(user.username).to.equal(pm.globals.get(\"test_username\"));\r",
							"    pm.expect(user.email).to.equal(pm.globals.get(\"test_email\"));\r",
							"    // Don't check user.id since we're using existing users\r",
							"});\r",
							"\r",
							"// Test 5: Response status should be 200 for successful login\r",
							"pm.test(\"Response status should be 200 for successful login\", () => {\r",
							"    pm.response.to.have.status(200);\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
