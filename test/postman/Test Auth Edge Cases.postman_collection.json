			"name": "Registration Edge Cases",
			"item": [
				{
					"name": "Test Register - Duplicate Username",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Use existing username",
									"const timestamp = Date.now();",
									"pm.request.body.raw = JSON.stringify({",
									"    username: pm.globals.get('test_username') || 'test_user_1754082456666',",
									"    email: `unique${timestamp}@example.com`,",
									"    password: 'MySecure123!Pass',",
									"    confirmPassword: 'MySecure123!Pass',",
									"    registrationToken: 'e6b1228b6525d690bfc64ab355db000c1d9a49d921c97bbb9166a627d200c66437d2dfd53f2ea1d3ae2e173593732935c11b9418507a79fb6f39864ba6b83fc6'",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Should reject duplicate username",
									"pm.test(\"Should return 400 for duplicate username\", () => {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"// Test 2: Error message validation",
									"pm.test(\"Error message should indicate username already exists\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('error');",
									"    pm.expect(response.error).to.match(/username.*already.*exists|taken/i);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/gdt/auth/register",
							"host": ["{{base_url}}"],
							"path": ["gdt", "auth", "register"]
						}
					}
				},
