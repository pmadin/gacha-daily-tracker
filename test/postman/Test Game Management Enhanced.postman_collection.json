				{
					"name": "Test Update - Audit Trail Verification",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.request.body.raw = JSON.stringify({",
									"    daily_reset: '05:00',",
									"    reason: 'Audit trail test - verifying logging'",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Update successful",
									"pm.test(\"Update should be successful\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Audit trail fields present",
									"pm.test(\"Response should contain audit trail information\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('updated_by');",
									"    pm.expect(response).to.have.property('update_reason');",
									"    pm.expect(response).to.have.property('changes_made');",
									"    ",
									"    pm.expect(response.updated_by).to.be.a('string').and.not.be.empty;",
									"    pm.expect(response.update_reason).to.equal('Audit trail test - verifying logging');",
									"    ",
									"    console.log(`✓ Audit trail: Updated by ${response.updated_by}`);",
									"    console.log(`✓ Reason: ${response.update_reason}`);",
									"});",
									"",
									"// Test 3: Changes tracked",
									"pm.test(\"Changes should be tracked with before/after values\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response.changes_made).to.have.property('daily_reset');",
									"    pm.expect(response.changes_made.daily_reset).to.include('→');",
									"    console.log(`✓ Change: ${response.changes_made.daily_reset}`);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/gdt/update/games/109",
							"host": ["{{base_url}}"],
							"path": ["gdt", "update", "games", "109"]
						}
					}
				}
