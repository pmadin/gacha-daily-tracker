{
	"info": {
		"name": "Test Game Management Enhanced",
		"description": "Additional game management tests for soft-delete, restore, and import scenarios",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Soft Delete & Restore Tests",
			"item": [
				{
					"name": "Test Soft Delete Game (is_active: false)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Soft delete by setting is_active to false",
									"pm.request.body.raw = JSON.stringify({",
									"    is_active: false,",
									"    reason: 'Testing soft delete functionality'",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Soft delete successful",
									"pm.test(\"Should successfully soft delete game\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Response indicates soft delete",
									"pm.test(\"Response should indicate soft delete operation\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('operation');",
									"    pm.expect(response.operation).to.match(/soft.*delete|deactivat/i);",
									"});",
									"",
									"// Test 3: Game is_active is false",
									"pm.test(\"Game should be marked as inactive\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response.game).to.have.property('is_active');",
									"    pm.expect(response.game.is_active).to.be.false;",
									"    console.log('✓ Game soft deleted (is_active = false)');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/gdt/update/games/109",
							"host": ["{{base_url}}"],
							"path": ["gdt", "update", "games", "109"]
						}
					}
				},
				{
					"name": "Test Restore Game (is_active: true)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Restore by setting is_active to true",
									"pm.request.body.raw = JSON.stringify({",
									"    is_active: true,",
									"    reason: 'Testing restore functionality'",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Restore successful",
									"pm.test(\"Should successfully restore game\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Response indicates restore",
									"pm.test(\"Response should indicate restore operation\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('operation');",
									"    pm.expect(response.operation).to.match(/restor/i);",
									"});",
									"",
									"// Test 3: Game is_active is true",
									"pm.test(\"Game should be marked as active\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response.game).to.have.property('is_active');",
									"    pm.expect(response.game.is_active).to.be.true;",
									"    console.log('✓ Game restored (is_active = true)');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/gdt/update/games/109",
							"host": ["{{base_url}}"],
							"path": ["gdt", "update", "games", "109"]
						}
					}
				}
			]
		},
		{
			"name": "Delete Endpoint Tests",
			"item": [
				{
					"name": "Test Delete Non-Existent Game",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.request.body.raw = JSON.stringify({",
									"    reason: 'Testing deletion of non-existent game',",
									"    permanent: true",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Should return 404",
									"pm.test(\"Should return 404 for non-existent game\", () => {",
									"    pm.response.to.have.status(404);",
									"});",
									"",
									"// Test 2: Error message validation",
									"pm.test(\"Error message should indicate game not found\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('error');",
									"    pm.expect(response.error).to.equal('Game not found');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/gdt/update/delete/game/9999",
							"host": ["{{base_url}}"],
							"path": ["gdt", "update", "delete", "game", "9999"]
						}
					}
				},
				{
					"name": "Test Delete Without Reason (Optional)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Empty body or no reason",
									"pm.request.body.raw = JSON.stringify({",
									"    permanent: false",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Delete should work without reason (it's optional)",
									"pm.test(\"Delete should work even without reason field\", () => {",
									"    // Could be 200 if reason is optional, or 400 if required",
									"    const validCodes = [200, 400];",
									"    pm.expect(validCodes).to.include(pm.response.code);",
									"});",
									"",
									"// Test 2: If successful, verify operation type",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Should indicate deletion type\", () => {",
									"        const response = pm.response.json();",
									"        pm.expect(response).to.have.property('deletion_type');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/gdt/update/delete/game/240",
							"host": ["{{base_url}}"],
							"path": ["gdt", "update", "delete", "game", "240"]
						}
					}
				}
			]
		},
		{
			"name": "Import Tests",
			"item": [
				{
					"name": "Test Import with Force Refresh",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.request.body.raw = JSON.stringify({",
									"    forceRefresh: true",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Import successful",
									"pm.test(\"Import with force refresh should succeed\", () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Response structure",
									"pm.test(\"Response should contain import statistics\", () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('imported');",
									"    pm.expect(response).to.have.property('updated');",
									"    pm.expect(response).to.have.property('total');",
									"    pm.expect(response).to.have.property('source');",
									"});",
									"",
									"// Test 3: Source should be remote when forceRefresh is true",
									"pm.test(\"Source should be remote with forceRefresh\", () => {",
									"    const response = pm.response.json();",
									"    // Source could be 'remote', 'github', or similar",
									"    pm.expect(response.source).to.not.equal('cache/backup');",
									"    console.log(`Import source: ${response.source}`);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
