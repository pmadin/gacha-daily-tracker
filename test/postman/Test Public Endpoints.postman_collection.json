        {
          "name": "Test Get Deleted Games - With Server Filter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Server filter applied",
                  "pm.test(\"Should filter deleted games by server\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: All results should be from Global server and deleted",
                  "pm.test(\"All results should be from Global server and deleted\", () => {",
                  "    const response = pm.response.json();",
                  "    if (response.deleted_games.length > 0) {",
                  "        response.deleted_games.forEach(game => {",
                  "            pm.expect(game.server).to.equal('Global');",
                  "            pm.expect(game.status).to.equal('soft deleted');",
                  "        });",
                  "    }",
                  "});"
