  "item": [
    {
      "name": "Deleted Games Tests",
      "item": [
        {
          "name": "Test Get Deleted Games",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Endpoint accessible",
                  "pm.test(\"Should return 200 for deleted games request\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Response structure",
                  "pm.test(\"Response should contain games array and pagination\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('deleted_games');  // was 'games'",
                  "    pm.expect(response.deleted_games).to.be.an('array');",
                  "    pm.expect(response).to.have.property('total_deleted');  // was 'total'",
                  "    pm.expect(response).to.have.property('limit');",
                  "    pm.expect(response).to.have.property('offset');",
                  "});",
                  "",
                  "// Test 3: Verify all games are deleted",
                  "pm.test(\"All returned games should be deleted (is_active = false)\", () => {",
                  "    const response = pm.response.json();",
                  "    if (response.deleted_games.length > 0) {       // was response.games",
                  "        response.deleted_games.forEach(game => {    // was response.games",
                  "            pm.expect(game).to.have.property('status');",
                  "            pm.expect(game.status).to.equal('soft deleted');  // was 'deleted'",
                  "        });",
                  "    }",
                  "});",
                  "",
                  "// Test 4: Game object structure",
                  "pm.test(\"Each deleted game should have required fields\", () => {",
                  "    const response = pm.response.json();",
                  "    if (response.deleted_games.length > 0) {       // was response.games",
                  "        const game = response.deleted_games[0];    // was response.games",
                  "        pm.expect(game).to.have.property('id');",
                  "        pm.expect(game).to.have.property('name');",
                  "        pm.expect(game).to.have.property('server');",
                  "        pm.expect(game).to.have.property('timezone');",
                  "        pm.expect(game).to.have.property('daily_reset');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "packages": {},
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/gdt/games/deleted",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "gdt",
                "games",
                "deleted"
              ]
            }
          },
          "response": []
        },
