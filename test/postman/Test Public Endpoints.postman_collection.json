        {
          "name": "Test Get Deleted Games - With Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Fixed to handle undefined response data",
                  "pm.test(\"Pagination should be applied to deleted games\", () => {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.limit).to.equal(10);",
                  "    pm.expect(response.offset).to.equal(0);",
                  "    pm.expect(response.deleted_games).to.exist; // Ensure deleted_games exists",
                  "    pm.expect(response.deleted_games.length).to.be.at.most(10);",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
