          "name": "Test Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Health endpoint accessible",
                  "pm.test(\"Health endpoint should return 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Response structure",
                  "pm.test(\"Health response should contain status and database info\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('status');",
                  "    pm.expect(response).to.have.property('database');",
                  "    pm.expect(response.database).to.be.an('object');",
                  "});",
                  "",
                  "// Test 3: Status is OK",
                  "pm.test(\"Overall status should be OK\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status).to.equal('OK');",
                  "});",
                  "",
                  "// Test 4: Database connection status",
                  "pm.test(\"Database should be connected\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.database).to.have.property('status');",
                  "    pm.expect(response.database.status).to.match(/connected|OK|healthy/i);",
                  "});",
                  "",
                  "// Test 5: Backup file status present",
                  "pm.test(\"Backup file status should be present\", () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('backup_file');",
                  "    pm.expect(response.backup_file).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
