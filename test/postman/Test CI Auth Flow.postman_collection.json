{
	"info": {
		"_postman_id": "ci-auth-flow-001",
		"name": "Test CI Auth Flow",
		"description": "Self-contained collection for CI: registers a fresh user, logs in, tests authenticated endpoints, then deletes the account. Requires {{registration_token}} to be set (passed via --env-var in CI).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Register CI Test User",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const ts = Date.now();",
							"pm.collectionVariables.set('ci_username', 'ci_user_' + ts);",
							"pm.collectionVariables.set('ci_email', 'ci_' + ts + '@test.com');",
							"pm.collectionVariables.set('ci_password', 'CiTestPass_' + ts + '!');"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Register returns 201', function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test('Response contains user object', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.have.property('user');",
							"    pm.expect(json.user).to.have.property('id');",
							"    pm.collectionVariables.set('ci_user_id', json.user.id);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n\t\"username\": \"{{ci_username}}\",\n\t\"email\": \"{{ci_email}}\",\n\t\"password\": \"{{ci_password}}\",\n\t\"registrationToken\": \"{{registration_token}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/gdt/auth/register",
					"host": ["{{base_url}}"],
					"path": ["gdt", "auth", "register"]
				}
			}
		},
		{
			"name": "Login CI Test User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Login returns 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response contains token', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.have.property('token');",
							"    pm.expect(json.token).to.be.a('string').and.not.empty;",
							"    pm.collectionVariables.set('ci_token', json.token);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n\t\"email\": \"{{ci_email}}\",\n\t\"password\": \"{{ci_password}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/gdt/auth/login",
					"host": ["{{base_url}}"],
					"path": ["gdt", "auth", "login"]
				}
			}
		},
		{
			"name": "Get Profile",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Get profile returns 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Profile matches registered user', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.have.property('user');",
							"    pm.expect(json.user.username).to.eql(pm.collectionVariables.get('ci_username'));",
							"    pm.expect(json.user.email).to.eql(pm.collectionVariables.get('ci_email'));",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{ci_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/gdt/auth/profile",
					"host": ["{{base_url}}"],
					"path": ["gdt", "auth", "profile"]
				}
			}
		},
		{
			"name": "Update Profile (timezone)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Update profile returns 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Timezone was updated', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json.user.timezone).to.eql('America/New_York');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{ci_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n\t\"timezone\": \"America/New_York\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/gdt/auth/profile",
					"host": ["{{base_url}}"],
					"path": ["gdt", "auth", "profile"]
				}
			}
		},
		{
			"name": "Delete Account (cleanup)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Delete account returns 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Deletion confirmed', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json.message).to.include('deleted');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{ci_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n\t\"password\": \"{{ci_password}}\",\n\t\"identifier\": \"{{ci_username}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/gdt/auth/account",
					"host": ["{{base_url}}"],
					"path": ["gdt", "auth", "account"]
				}
			}
		}
	],
	"variable": [
		{
			"key": "ci_username",
			"value": ""
		},
		{
			"key": "ci_email",
			"value": ""
		},
		{
			"key": "ci_password",
			"value": ""
		},
		{
			"key": "ci_token",
			"value": ""
		},
		{
			"key": "ci_user_id",
			"value": ""
		}
	]
}
