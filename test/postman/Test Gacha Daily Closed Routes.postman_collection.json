		{
			"name": "Test update by daily reset",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Generate a new reset time for testing\r",
							"const hours = Math.floor(Math.random() * 24).toString().padStart(2, '0');\r",
							"const minutes = Math.floor(Math.random() * 60).toString().padStart(2, '0');\r",
							"const newResetTime = `${hours}:${minutes}`;\r",
							"\r",
							"pm.collectionVariables.set('test_reset_time', newResetTime);\r",
							"\r",
							"// Set up request body - MUST be a JSON string, not an object\r",
							"const requestBody = {\r",
							"    daily_reset: newResetTime,\r",
							"    reason: \"Testing daily reset time update via Postman\"\r",
							"};\r",
							"\r",
							"pm.request.body.raw = JSON.stringify(requestBody);\r",
							"\r",
							"// Make sure Content-Type is set to application/json\r",
							"pm.request.headers.upsert({\r",
							"    key: 'Content-Type',\r",
							"    value: 'application/json'\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test 1: Authentication and authorization check\r",
							"pm.test(\"Response status should be 200 with valid bearer token\", () => {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"// Test 2: Validate response structure matches documentation\r",
							"pm.test(\"Response should contain required fields from documentation\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response).to.have.property('message');\r",
							"    pm.expect(response.message).to.equal('Game updated successfully');\r",
							"    pm.expect(response).to.have.property('game');\r",
							"    pm.expect(response).to.have.property('updated_by');\r",
							"    pm.expect(response).to.have.property('update_reason');\r",
							"    pm.expect(response).to.have.property('changes_made');\r",
							"});\r",
							"\r",
							"// Test 3: Validate game object contains updated daily_reset\r",
							"pm.test(\"Game should contain updated daily_reset time\", () => {\r",
							"    const response = pm.response.json();\r",
							"    const expectedResetTime = pm.collectionVariables.get('test_reset_time');\r",
							"    \r",
							"    pm.expect(response.game).to.have.property('daily_reset');\r",
							"    pm.expect(response.game.daily_reset).to.equal(expectedResetTime + ':00');\r",
							"    console.log(`✓ Daily reset updated to: ${response.game.daily_reset}`);\r",
							"});\r",
							"\r",
							"// Test 4: Validate changes_made field shows the change\r",
							"pm.test(\"Changes made field should reflect daily_reset update\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response.changes_made).to.have.property('daily_reset');\r",
							"    pm.expect(response.changes_made.daily_reset).to.be.a('string');\r",
							"    pm.expect(response.changes_made.daily_reset).to.include('→');\r",
							"    console.log(`Change tracking: ${response.changes_made.daily_reset}`);\r",
							"});\r",
							"\r",
							"// Test 5: Validate updated_by field contains username\r",
							"pm.test(\"Updated by field should contain username\", () => {\r",
							"    const response = pm.response.json();\r",
							"    pm.expect(response.updated_by).to.be.a('string').and.not.be.empty;\r",
							"    console.log(`Updated by: ${response.updated_by}`);\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
