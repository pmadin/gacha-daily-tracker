							"    pm.expect(tracked).to.exist;",
							"    pm.expect(tracked.completed_today).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "Authorization", "value": "Bearer {{regular_user_token}}" }],
				"url": { "raw": "{{base_url}}/gdt/tracker/games", "host": ["{{base_url}}"], "path": ["gdt", "tracker", "games"] }
			}
		},
		{
			"name": "10. Unmark Daily",
			"event": [
				{
					"listen": "test",
					"script": {
