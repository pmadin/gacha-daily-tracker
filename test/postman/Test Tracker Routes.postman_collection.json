			"request": {
				"method": "GET",
				"header": [{ "key": "Authorization", "value": "Bearer {{regular_user_token}}" }],
				"url": { "raw": "{{base_url}}/gdt/tracker/games", "host": ["{{base_url}}"], "path": ["gdt", "tracker", "games"] }
			}
		},
		{
			"name": "12. Bulk Add Games (2 valid + 1 invalid)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Returns 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('added = 2, invalid_ids includes 99999', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json.added).to.eql(2);",
							"    pm.expect(json.invalid_ids).to.include(99999);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{regular_user_token}}" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n\t\"gameIds\": [{{game_id_2}}, {{game_id_3}}, 99999]\n}"
				},
				"url": { "raw": "{{base_url}}/gdt/tracker/games/bulk", "host": ["{{base_url}}"], "path": ["gdt", "tracker", "games", "bulk"] }
			}
		},
		{
			"name": "13. Bulk Add with Empty Array (should be 400)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Returns 400', function () {",
							"    pm.response.to.have.status(400);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer {{regular_user_token}}" },
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": { "mode": "raw", "raw": "{\n\t\"gameIds\": []\n}" },
				"url": { "raw": "{{base_url}}/gdt/tracker/games/bulk", "host": ["{{base_url}}"], "path": ["gdt", "tracker", "games", "bulk"] }
			}
		},
		{
			"name": "14. Verify 3 Games Now Tracked",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Returns 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('Total is at least 3', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json.total).to.be.at.least(3);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [{ "key": "Authorization", "value": "Bearer {{regular_user_token}}" }],
