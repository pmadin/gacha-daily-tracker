				"url": { "raw": "{{base_url}}/gdt/tracker/games/99999/complete", "host": ["{{base_url}}"], "path": ["gdt", "tracker", "games", "99999", "complete"] }
			}
		},
		{
			"name": "9. Verify completed_today = true",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Returns 200', function () {",
							"    pm.response.to.have.status(200);",
